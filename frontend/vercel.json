{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https://viteee-prep-backend.onrender.com; style-src 'self' 'unsafe-inline';"
        }
      ]
    }
  ]
}
